# All API keys are configured PER PROFILE in the web portal (/configure) and
# stored in DATA_DIR/profiles.json — nothing secret goes in this file.
PORT=7000
DATA_DIR=./data
STALE_HOURS=24
BACKOFF_MINUTES=30
# Admin portal Basic Auth — portal is unprotected if either is unset
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Public hostname for install URLs & manifest logo (Cloudflare Tunnel etc.).
# Without it, links use whatever address you opened the portal from — fine on
# LAN, broken for Stremio clients outside your network.
EXTERNAL_URL=https://recs.example.com
