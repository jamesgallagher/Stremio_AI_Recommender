# All API keys are configured PER PROFILE in the web portal (/configure) and
# stored in DATA_DIR/profiles.json — nothing secret goes in this file.
PORT=7000
DATA_DIR=./data
STALE_HOURS=24
BACKOFF_MINUTES=30
# Override the Groq model fallback chain (best first). Default:
# openai/gpt-oss-120b,llama-3.3-70b-versatile,openai/gpt-oss-20b,llama-3.1-8b-instant
# GROQ_MODELS=openai/gpt-oss-120b,llama-3.3-70b-versatile
# Admin portal Basic Auth — portal is unprotected if either is unset
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Encrypts ALL stored secrets at rest (API keys, Trakt tokens, Auto-scrobble
# passwords) with AES-256-GCM. Any long random string. Existing plaintext
# secrets are encrypted on the next start. Keep it off the /data volume so a
# leaked backup can't decrypt anything, and back it up (losing it = re-enter
# keys + re-auth Trakt). SCROBBLE_KEY is still accepted as a legacy alias.
# SECRET_KEY=change-me-to-a-long-random-string
# Public hostname for install URLs & manifest logo (Cloudflare Tunnel etc.).
# Without it, links use whatever address you opened the portal from — fine on
# LAN, broken for Stremio clients outside your network.
EXTERNAL_URL=https://recs.example.com
